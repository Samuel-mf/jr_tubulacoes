
PORT=3000
NODE_ENV=production

# ── Executor-Service (Command Bus) ──────────────────────────────────────
# URL do executor-service central da plataforma Flowbuilding
API_URL=https://api.flowbuilding.com
# Chave de API do projeto jr_tubulacoes (identifica o tenant no executor)
EXECUTOR_API_KEY=proj-<sua-chave-aqui>

# ── Admin local (JWT) ────────────────────────────────────────────────────
JWT_SECRET=<gere-um-secret-forte>
ADMIN_USER=jrtubulacao
ADMIN_PASS=<senha-forte-aqui>

# ── Configurações do site ────────────────────────────────────────────────
WHATSAPP_NUMBER=5519998038607

# ── reCAPTCHA ────────────────────────────────────────────────────────────
RECAPTCHA_SITE_KEY=6Lc...
RECAPTCHA_SECRET_KEY=6Lc...

# ── LEGADO (pendente migração para executor-service) ─────────────────────
DB_HOST=infra_postgres
DB_PORT=5432
DB_NAME=infra
DB_USER=flowbuilding
DB_PASS=<senha-do-banco>
